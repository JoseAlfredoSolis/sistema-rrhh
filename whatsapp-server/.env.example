# Copiá este archivo a ".env" y completá los valores antes de arrancar el servidor.

# Puerto donde escucha el servidor HTTP.
PORT=3000

# Secreto compartido que Apps Script debe mandar en el header
# "Authorization: Bearer <WEBHOOK_SECRET>" para poder usar /enviar.
# Generá algo largo y random, por ejemplo con: openssl rand -hex 32
WEBHOOK_SECRET=

# Carpeta donde se guarda la sesión de WhatsApp vinculada (credenciales).
# NUNCA subas esta carpeta a git ni la compartas — equivale a tener acceso
# a la cuenta de WhatsApp vinculada.
AUTH_DIR=./auth_info_baileys
